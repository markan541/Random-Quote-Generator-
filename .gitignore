import tkinter as tk
from tkinter import ttk, messagebox, scrolledtext
import json
import random
import os
from datetime import datetime

class QuoteGenerator:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Quote Generator")
        self.root.geometry("800x600")
        self.root # Загрузка данных
        self.quotes_file = "quotes_data.json"
        self.quotes = []          # Список цитат: [{"text": "...", "author": "...", "theme": "..."}]
        self.history = []         # Список истории: [{"text": "...", "author": "...", "theme": "...", "timestamp": "..."}]
        
        self.load_data()
        
        # Если нет цитат, добавляем предопределённые
        if not self.quotes:
            self.init_default_quotes()
            self.save_quotes()
        
        # UI компоненты
        self.create_widgets()
        self.update_quote_list()
        self.update_history_list()
        
    def init_default_quotes(self):
        """Инициализация предопределённых цитат"""
        default_quotes = [
            {"text": "Будь изменением, которое ты хочешь видеть в мире.", "author": "Махатма Ганди", "theme": "Мотивация"},
            {"text": "Жизнь — это то, что с тобой происходит, пока ты строишь планы.", "author": "Джон Леннон", "theme": "Философия"},
            {"text": "Не бойся совершенства — тебе его не достичь.", "author": "Сальвадор Дали", "theme": "Искусство"},
            {"text": "Единственный способ делать великую работу — любить то, что ты делаешь.", "author": "Стив Джобс", "theme": "Мотивация"},
            {"text": "Будущее зависит от того, что ты делаешь сегодня.", "author": "Махатма Ганди", "theme": "Мотивация"},
            {"text": "Воображение важнее знания.", "author": "Альберт Эйнштейн", "theme": "Наука"},
            {"text": "Будь собой, все остальные роли уже заняты.", "author": "Оскар Уайльд", "theme": "Философия"},
            {"text": "Тот, кто двигает горы, начинает с маленьких камней.", "author": "Конфуций", "theme": "Мудрость"},
            {"text": "Инвестиции в знания дают наибольшую прибыль.", "author": "Бенджамин Франклин", "theme": "Образование"},
            {"text": "Трудности делают нас сильнее.", "author": "Сенека", "theme": "Философия"},
        ]
        self.quotes = default_quotes
            
    def create_widgets(self):
        # Верхняя панель с кнопками
        top_frame = tk.Frame(self.root)
        top_frame.pack(pady=10)
        
        self.generate_btn = tk.Button(top_frame, text="🎲 Сгенерировать цитату", 
                                      font=("Arial", 12, "bold"), 
                                      command=self.generate_random_quote,
                                      bg="#4CAF50", fg="white", padx=20, pady=5)
        self.generate_btn.pack(side=tk.LEFT, padx=5)
        
        # Рамка для добавления новой цитаты
        add_frame = tk.LabelFrame(self.root, text="Добавить новую цитату", padx=10, pady=10)
        add_frame.pack(fill=tk.X, padx=10, pady=5)
        
        tk.Label(add_frame, text="Текст цитаты:").grid(row=0, column=0, sticky=tk.W, pady=2)
        self.text_entry = tk.Text(add_frame, height=3, width=60)
        self.text_entry.grid(row=0, column=1, padx=5, pady=2)
        
        tk.Label(add_frame, text="Автор:").grid(row=1, column=0, sticky=tk.W, pady=2)
        self.author_entry = tk.Entry(add_frame, width=30)
        self.author_entry.grid(row=1, column=1, sticky=tk.W, padx=5, pady=2)
        
        tk.Label(add_frame, text="Тема:").grid(row=2, column=0, sticky=tk.W, pady=2)
        self.theme_entry = tk.Entry(add_frame, width=30)
        self.theme_entry.grid(row=2, column=1, sticky=tk.W, padx=5, pady=2)
        
        self.add_quote_btn = tk.Button(add_frame, text="➕ Добавить цитату", 
                                       command=self.add_new_quote,
                                       bg="#2196F3", fg="white")
        self.add_quote_btn.grid(row=3, column=1, sticky=tk.W, pady=5)
        
        # Панель фильтрации
        filter_frame = tk.LabelFrame(self.root, text="Фильтрация", padx=10, pady=5)
        filter_frame.pack(fill=tk.X, padx=10, pady=5)
        
        tk.Label(filter_frame, text="Фильтр по автору:").grid(row=0, column=0, padx=5, pady=2)
        self.author_filter = ttk.Combobox(filter_frame, values=self.get_unique_authors(), width=20)
        self.author_filter.grid(row=0, column=1, padx=5, pady=2)
        self.author_filter.bind('<<ComboboxSelected>>', self.apply_filter)
        
        tk.Label(filter_frame, text="Фильтр по теме:").grid(row=0, column=2, padx=5, pady=2)
        self.theme_filter = ttk.Combobox(filter_frame, values=self.get_unique_themes(), width=20)
        self.theme_filter.grid(row=0, column=3, padx=5, pady=2)
        self.theme_filter.bind('<<ComboboxSelected>>', self.apply_filter)
        
        self.clear_filter_btn = tk.Button(filter_frame, text="❌ Очистить фильтры", 
                                          command=self.clear_filters,
                                          bg="#FF9800", fg="white")
        self.clear_filter_btn.grid(row=0, column=4, padx=10, pady=2)
        
        # Основная область: список цитат и история
        main_frame = tk.Frame(self.root)
        main_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)
        
        # Список доступных цитат
        left_frame = tk.LabelFrame(main_frame, text="Все цитаты", padx=5, pady=5)
        left_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5)
        
        self.quote_listbox = tk.Listbox(left_frame, height=15, font=("Arial", 10))
        self.quote_listbox.pack(fill=tk.BOTH, expand=True)
        scrollbar_q = tk.Scrollbar(self.quote_listbox, command=self.quote_listbox.yview)
        self.quote_listbox.configure(yscrollcommand=scrollbar_q.set)
        
        # История сгенерированных цитат
        right_frame = tk.LabelFrame(main_frame, text="История цитат", padx=5, pady=5)
        right_frame.pack(side=tk.RIGHT, fill=tk.BOTH, expand=True, padx=5)
        
        self.history_listbox = tk.Listbox(right_frame, height=15, font=("Arial", 9))
        self.history_listbox.pack(fill=tk.BOTH, expand=True)
        scrollbar_h = tk.Scrollbar(self.history_listbox, command=self.history_listbox.yview)
        self.history_listbox.configure(yscrollcommand=scrollbar_h.set)
        
        # Текущая сгенерированная цитата
        current_frame = tk.LabelFrame(self.root, text="Текущая цитата", padx=10, pady=10)
        current_frame.pack(fill=tk.X, padx=10, pady=5)
        
        self.current_quote_text = tk.Text(current_frame, height=4, wrap=tk.WORD, font=("Arial", 11, "italic"))
        self.current_quote_text.pack(fill=tk.X)
        self.current_quote_text.config(state=tk.DISABLED)
        
    def get_unique_authors(self):
        return sorted(list(set([q['author'] for q in self.quotes])))
    
    def get_unique_themes(self):
        return sorted(list(set([q['theme'] for q in self.quotes])))
    
    def apply_filter(self, event=None):
        """Применение фильтрации по автору и/или теме"""
        author = self.author_filter.get()
        theme = self.theme_filter.get()
        
        filtered = self.quotes
        if author:
            filtered = [q for q in filtered if q['author'] == author]
        if theme:
            filtered = [q for q in filtered if q['theme'] == theme]
        
        self.update_quote_list(filtered)
        
    def clear_filters(self):
        """Очистка всех фильтров"""
        self.author_filter.set('')
        self.theme_filter.set('')
        self.update_quote_list(self.quotes)
    
    def update_quote_list(self, quote_list=None):
        """Обновление списка цитат в интерфейсе"""
        self.quote_listbox.delete(0, tk.END)
        quotes_to_show = quote_list if quote_list is not None else self.quotes
        
        for q in quotes_to_show:
            display_text = f"{q['text'][:50]}... — {q['author']} [{q['theme']}]"
            self.quote_listbox.insert(tk.END, display_text)
    
    def update_history_list(self):
        """Обновление истории в интерфейсе"""
        self.history_listbox.delete(0, tk.END)
        for h in reversed(self.history):  # Сначала новые
            timestamp = h.get('timestamp', 'N/A')
            display_text = f"[{timestamp}] {h['text'][:50]}... — {h['author']}"
            self.history_listbox.insert(tk.END, display_text)
    
    def generate_random_quote(self):
        """Генерация случайной цитаты с учётом фильтров"""
        author = self.author_filter.get()
        theme = self.theme_filter.get()
        
        available_quotes = self.quotes
        if author:
            available_quotes = [q for q in available_quotes if q['author'] == author]
        if theme:
            available_quotes = [q for q in available_quotes if q['theme'] == theme]
        
        if not available_quotes:
            messagebox.showwarning("Нет цитат", "Нет цитат, соответствующих фильтрам!")
            return
        
        quote = random.choice(available_quotes)
        
        # Отображение текущей цитаты
        self.current_quote_text.config(state=tk.NORMAL)
        self.current_quote_text.delete(1.0, tk.END)
        quote_display = f"«{quote['text']}»\n\n— {quote['author']} (Тема: {quote['theme']})"
        self.current_quote_text.insert(1.0, quote_display)
        self.current_quote_text.config(state=tk.DISABLED)
        
        # Сохранение в историю
        history_entry = quote.copy()
        history_entry['timestamp'] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self.history.append(history_entry)
        self.update_history_list()
        self.save_history()
        
    def add_new_quote(self):
        """Добавление новой цитаты с проверкой ввода"""
        text = self.text_entry.get(1.0, tk.END).strip()
        author = self.author_entry.get().strip()
        theme = self.theme_entry.get().strip()
        
        # Валидация
        if not text:
            messagebox.showerror("Ошибка", "Текст цитаты не может быть пустым!")
            return
        if not author:
            messagebox.showerror("Ошибка", "Автор не может быть пустым!")
            return
        if not theme:
            messagebox.showerror("Ошибка", "Тема не может быть пустой!")
            return
        
        new_quote = {"text": text, "author": author, "theme": theme}
        self.quotes.append(new_quote)
        self.save_quotes()
        
        # Очистка полей
        self.text_entry.delete(1.0, tk.END)
        self.author_entry.delete(0, tk.END)
        self.theme_entry.delete(0, tk.END)
        
        # Обновление фильтров
        self.update_filters_comboboxes()
        self.update_quote_list()
        
        messagebox.showinfo("Успех", "Цитата успешно добавлена!")
    
    def update_filters_comboboxes(self):
        """Обновление значений в выпадающих списках фильтров"""
        self.author_filter['values'] = self.get_unique_authors()
        self.theme_filter['values'] = self.get_unique_themes()
    
    def save_quotes(self):
        """Сохранение списка цитат в JSON"""
        try:
            with open(self.quotes_file, 'w', encoding='utf-8') as f:
                json.dump({"quotes": self.quotes}, f, ensure_ascii=False, indent=2)
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить цитаты: {e}")
    
    def save_history(self):
        """Сохранение истории в JSON"""
        try:
            with open(self.quotes_file, 'r+', encoding='utf-8') as f:
                data = json.load(f)
                data['history'] = self.history
                f.seek(0)
                json.dump(data, f, ensure_ascii=False, indent=2)
        except:
            # Если файла нет или он повреждён
            with open(self.quotes_file, 'w', encoding='utf-8') as f:
                json.dump({"quotes": self.quotes, "history": self.history}, f, ensure_ascii=False, indent=2)
    
    def load_data(self):
        """Загрузка данных из JSON"""
        if os.path.exists(self.quotes_file):
            try:
                with open(self.quotes_file, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                    self.quotes = data.get('quotes', [])
                    self.history = data.get('history', [])
            except:
                self.quotes = []
                self.history = []

if __name__ == "__main__":
    root = tk.Tk()
    app = QuoteGenerator(root)
    root.mainloop()
